generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  journals     Journal[]
  routineItems RoutineItem[]
  sessions     Session[]
  tasks        Task[]
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoutineItem {
  id        Int      @id @default(autoincrement())
  activity  String
  time      String
  duration  Int
  order     Int?
  completed Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Task {
  id        Int      @id @default(autoincrement())
  activity  String
  priority  Priority
  deadline  DateTime
  completed Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Journal {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  mood      Int
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}
